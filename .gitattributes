# Set default behavior for all files
* text=auto

# Python files should always use LF line endings
*.py text eol=lf

# YAML files should always use LF line endings
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts should always use LF line endings
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.exe binary